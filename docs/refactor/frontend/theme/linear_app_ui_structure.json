{
  "app_structure": {
    "layout": "sidebar + main content",
    "sidebar_position": "left",
    "navigation_type": "vertical",
    "theme_mode": "dark"
  },
  "navigation": {
    "workspace_menu": {
      "type": "dropdown",
      "display": "workspace initials + name",
      "actions": ["search workspace", "create new issue"]
    },
    "main_sections": {
      "quick_access": {
        "items": ["Inbox", "My issues"]
      },
      "workspace": {
        "expandable": true,
        "items": ["Projects", "Views", "More..."]
      },
      "teams": {
        "expandable": true,
        "items": ["Team name with Issues/Projects/Views"]
      },
      "onboarding": {
        "title": "Try",
        "dismissible_items": [
          "Import issues",
          "Invite people",
          "Link GitHub"
        ]
      }
    }
  },
  "main_content": {
    "header": {
      "title_level": "h2",
      "tabs_below_title": "optional"
    },
    "toolbar": {
      "left_items": ["Display options"],
      "right_items": ["Create new", "Action buttons"]
    },
    "content_area": {
      "empty_state": "illustration + description + call-to-action",
      "list_view": "table/grid layout",
      "detail_view": "side panel or full page"
    }
  },
  "color_palette": {
    "theme": "dark mode with LCH color space",
    "primary_text": "lch(100% 0 272 / 1)",
    "secondary_text": "lch(90.65% 1.35 272 / 1)",
    "backgrounds": {
      "page": "lch(4.8% 0.7 272)",
      "surface": "lch(10.633% 3.033 272 / 1)",
      "surface_elevated": "lch(14.133% 4.2 272 / 1)"
    },
    "borders": {
      "subtle": "lch(9.77% 3.54 272 / 1)",
      "light": "lch(14.74% 3.54 272 / 1)",
      "medium": "lch(19% 3.54 272 / 1)"
    },
    "accent": {
      "primary": "lch(55 60 300)",
      "bright": "rgb(0, 143, 255)",
      "focus_ring": "lch(47.918% 59.303 288.421)"
    }
  },
  "typography": {
    "font_family": "\"Inter Variable\",\"SF Pro Display\",-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Oxygen,Ubuntu,Cantarell,\"Open Sans\",\"Helvetica Neue\",\"Linear Thai\",sans-serif",
    "font_display": "same as regular",
    "font_monospace": "\"Berkeley Mono\",\"SFMono Regular\",Consolas,\"Liberation Mono\",Menlo,Courier,monospace",
    "font_weights": {
      "light": 300,
      "normal": 450,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "sizes": {
      "title_1": "2.25rem",
      "title_2": "1.5rem",
      "title_3": "1.25rem",
      "large": "1.125rem",
      "regular": "0.9375rem",
      "small": "0.8125rem",
      "micro": "0.6875rem"
    }
  },
  "spacing": {
    "editor": {
      "block_spacing": "1rem",
      "block_spacing_small": "0.375rem",
      "block_spacing_large": "1.375rem",
      "safe_area": "16px",
      "list_inset": "1.5rem"
    },
    "layout": {
      "sidebar_width": "244px",
      "sidebar_height": "100vh",
      "min_tap_target": "44px"
    }
  },
  "components": {
    "sidebar": {
      "width": 244,
      "sections": [
        {
          "name": "Workspace Menu",
          "items": ["workspace_selector", "search_button", "create_issue_button"]
        },
        {
          "name": "Main Navigation",
          "collapsible": false,
          "items": ["Inbox", "My issues"]
        },
        {
          "name": "Workspace Navigation",
          "collapsible": true,
          "items": ["Projects", "Views", "More"]
        },
        {
          "name": "Teams",
          "collapsible": true,
          "items": ["team_list_with_actions"]
        },
        {
          "name": "Onboarding Tips",
          "dismissible": true,
          "items": ["Import issues", "Invite people", "Link GitHub"]
        }
      ],
      "background": "solid color, light or dark variant",
      "text_color": "high contrast white/light gray"
    },
    "button": {
      "variants": [
        {
          "name": "primary",
          "background": "bright blue",
          "text": "white",
          "border": "none"
        },
        {
          "name": "secondary",
          "background": "surface color",
          "text": "primary text",
          "border": "subtle border"
        },
        {
          "name": "ghost",
          "background": "transparent",
          "text": "primary text",
          "border": "none"
        }
      ],
      "sizes": ["small", "medium", "large"],
      "states": ["default", "hover", "active", "disabled", "focus"]
    },
    "input": {
      "background": "surface color",
      "border": "subtle border",
      "border_focus": "bright blue focus ring",
      "text": "primary text",
      "placeholder": "tertiary text",
      "padding": "0.5rem to 1rem depending on size"
    },
    "card": {
      "background": "surface color",
      "border": "subtle border",
      "border_radius": "6px to 12px",
      "shadow": "subtle shadow on hover",
      "padding": "1rem to 1.5rem"
    },
    "navigation_item": {
      "default": {
        "background": "transparent",
        "text": "secondary text",
        "icon": "secondary text"
      },
      "hover": {
        "background": "elevated surface color",
        "text": "primary text"
      },
      "active": {
        "background": "subtle accent",
        "text": "primary text",
        "indicator": "bright accent color left border or dot"
      }
    },
    "editor_block": {
      "background": "surface color",
      "border": "subtle border",
      "border_radius": "6px",
      "padding": "1rem",
      "font_size": "0.9375rem",
      "line_height": 1.6,
      "features": [
        "rich text formatting",
        "collaborative editing",
        "inline comments",
        "code blocks with syntax highlighting"
      ]
    }
  },
  "animations": {
    "quick_transition": "0.1s ease-out",
    "regular_transition": "0.25s ease-out",
    "slow_transition": "0.35s ease-out",
    "fade_in": "0s (instant or very quick)",
    "fade_out": "0.15s"
  },
  "responsive_breakpoints": {
    "mobile": {
      "max_width": 600,
      "sidebar": "collapsed/drawer",
      "content": "full width"
    },
    "tablet": {
      "min_width": 600,
      "max_width": 1200,
      "sidebar": "visible/collapsible",
      "content": "adaptive width"
    },
    "desktop": {
      "min_width": 1200,
      "sidebar": "always visible",
      "content": "full width available"
    }
  },
  "accessibility": {
    "focus_ring": {
      "width": "1px",
      "color": "lch(47.918% 59.303 288.421)",
      "offset": "0px"
    },
    "contrast_ratios": {
      "normal_text": "7:1 or higher",
      "large_text": "4.5:1 or higher",
      "highlights": "high contrast for visibility"
    },
    "keyboard_navigation": "full support",
    "screen_reader_support": "ARIA labels and semantic HTML",
    "min_touch_target": "44px x 44px"
  },
  "editor_features": {
    "formatting": [
      "bold (**text**)",
      "italic (*text*)",
      "strikethrough (~~text~~)",
      "code (`text`)",
      "links ([text](url))"
    ],
    "block_elements": [
      "headings (h1-h6)",
      "paragraphs",
      "ordered lists",
      "unordered lists",
      "blockquotes",
      "code blocks",
      "checklists",
      "images"
    ],
    "collaborative": [
      "real-time cursor tracking",
      "presence indicators",
      "version history",
      "inline comments",
      "mentions (@username)"
    ],
    "shortcuts": [
      "Cmd+B for bold",
      "Cmd+I for italic",
      "Cmd+K for link",
      "Option+V to save view"
    ]
  }
}
